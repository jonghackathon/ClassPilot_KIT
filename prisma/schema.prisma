generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum LessonStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  LATE
  EARLY_LEAVE
  ABSENT
}

enum HomeworkStatus {
  COMPLETE
  INCOMPLETE
}

enum AssignmentType {
  CODING
  ESSAY
  IMAGE
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIAL
}

enum ConsultationType {
  PHONE
  TEXT
  IN_PERSON
}

enum MemoCategory {
  NOTICE
  NOTABLE
  STUDENT_NOTE
  OTHER
}

enum ComplaintStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

enum ChurnLevel {
  SAFE
  WARNING
  DANGER
}

enum CopilotSessionStatus {
  ACTIVE
  COMPLETED
}

enum RecordingStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum BotQuestionStatus {
  PENDING
  AI_ANSWERED
  TEACHER_ANSWERED
}

model Academy {
  id         String            @id @default(cuid())
  name       String
  logoUrl    String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  users      User[]
  classes    Class[]
  curricula  CurriculumClass[]
  settings   AppSetting[]
}

model User {
  id                   String             @id @default(cuid())
  academyId            String
  email                String             @unique
  emailVerified        DateTime?
  password             String?
  name                 String
  phone                String?
  image                String?
  role                 UserRole
  active               Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  academy              Academy            @relation(fields: [academyId], references: [id], onDelete: Cascade)
  studentProfile       StudentProfile?
  taughtClasses        ClassTeacher[]     @relation("TeacherClasses")
  enrollments          Enrollment[]
  attendances          Attendance[]
  teachingAssignments  Assignment[]       @relation("TeacherAssignments")
  submissions          Submission[]
  memos                Memo[]             @relation("TeacherMemos")
  ownedConsultations   Consultation[]     @relation("ConsultationOwner")
  studentConsultations Consultation[]     @relation("ConsultationStudent")
  payments             Payment[]          @relation("PaymentStudent")
  reports              ReportData[]
  complaints           Complaint[]        @relation("ComplaintStudent")
  churnPredictions     ChurnPrediction[]
  botQuestions         BotQuestion[]
  reviewSummaries      ReviewSummary[]
  copilotSessions      CopilotSession[]   @relation("CopilotTeacher")
  accounts             Account[]
  sessions             Session[]
}

model StudentProfile {
  id         String          @id @default(cuid())
  userId     String          @unique
  grade      String?
  school     String?
  birthDate  DateTime?
  memo       String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parents    ParentContact[]
}

model ParentContact {
  id               String         @id @default(cuid())
  studentProfileId String
  name             String
  phone            String
  relation         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
}

model CurriculumClass {
  id         String    @id @default(cuid())
  academyId  String
  name       String
  subject    String?
  level      String?
  stages     Json
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  academy    Academy   @relation(fields: [academyId], references: [id], onDelete: Cascade)
  classes    Class[]
}

model Class {
  id           String           @id @default(cuid())
  academyId    String
  curriculumId String?
  name         String
  subject      String?
  level        String?
  description  String?
  capacity     Int              @default(10)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  academy      Academy          @relation(fields: [academyId], references: [id], onDelete: Cascade)
  curriculum   CurriculumClass? @relation(fields: [curriculumId], references: [id], onDelete: SetNull)
  teachers     ClassTeacher[]
  enrollments  Enrollment[]
  schedules    Schedule[]
  lessons      Lesson[]
  assignments  Assignment[]
  attendances  Attendance[]
  payments     Payment[]
  weekNotes    WeekNote[]
  memos        Memo[]
  botQuestions BotQuestion[]
  faqs         BotFAQ[]
}

model ClassTeacher {
  id        String   @id @default(cuid())
  classId   String
  teacherId String
  createdAt DateTime @default(now())
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher   User     @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([classId, teacherId])
}

model Enrollment {
  id        String   @id @default(cuid())
  classId   String
  studentId String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
}

model Schedule {
  id        String   @id @default(cuid())
  classId   String
  dayOfWeek Int
  startTime String
  endTime   String
  room      String?
  color     String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
  weekNotes WeekNote[]

  @@index([classId, dayOfWeek])
}

model Lesson {
  id              String           @id @default(cuid())
  classId         String
  scheduleId      String?
  date            DateTime
  topic           String?
  status          LessonStatus     @default(SCHEDULED)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  class           Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  schedule        Schedule?        @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  attendances     Attendance[]
  copilotSessions CopilotSession[]
  recordings      RecordingSummary[]
  reviews         ReviewSummary[]
  weekNotes       WeekNote[]

  @@index([classId, date])
}

model Attendance {
  id             String           @id @default(cuid())
  classId        String
  studentId      String
  lessonId       String?
  date           DateTime
  status         AttendanceStatus
  homeworkStatus HomeworkStatus?
  homeworkNote   String?
  absenceReason  String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  class          Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  student        User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson         Lesson?          @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@unique([date, studentId, classId])
  @@index([classId, date])
}

model Assignment {
  id          String         @id @default(cuid())
  classId     String
  teacherId   String
  title       String
  content     String?
  type        AssignmentType @default(ESSAY)
  dueDate     DateTime?
  teacherNote String?
  imageUrls   String[]       @default([])
  feedback    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  class       Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher     User           @relation("TeacherAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([classId, dueDate])
}

model Submission {
  id            String           @id @default(cuid())
  assignmentId  String
  studentId     String
  content       String?
  attachments   String[]         @default([])
  aiUsed        Boolean          @default(false)
  aiUsageDetail String?
  submittedAt   DateTime?
  status        SubmissionStatus @default(DRAFT)
  teacherFeedback String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  assignment    Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student       User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  history       SubmissionHistory[]

  @@unique([assignmentId, studentId])
}

model SubmissionHistory {
  id           String     @id @default(cuid())
  submissionId String
  content      String
  attachments  String[]   @default([])
  charCount    Int
  createdAt    DateTime   @default(now())
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, createdAt])
}

model WeekNote {
  id               String    @id @default(cuid())
  classId          String
  scheduleId       String?
  lessonId         String?
  date             DateTime
  content          String
  studentReaction  String?
  curriculumStage  String?
  curriculumLesson String?
  autoAssign       Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  class            Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  schedule         Schedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  lesson           Lesson?   @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@unique([classId, date])
}

model Payment {
  id        String        @id @default(cuid())
  studentId String
  classId   String
  amount    Int
  status    PaymentStatus @default(UNPAID)
  month     String
  paidAt    DateTime?
  note      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  student   User          @relation("PaymentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  class     Class         @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId, month])
}

model Consultation {
  id        String           @id @default(cuid())
  studentId String
  ownerId   String
  type      ConsultationType
  content   String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  student   User             @relation("ConsultationStudent", fields: [studentId], references: [id], onDelete: Cascade)
  owner     User             @relation("ConsultationOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
}

model Memo {
  id         String       @id @default(cuid())
  teacherId  String
  classId    String?
  title      String?
  content    String
  category   MemoCategory
  targetName String?
  archived   Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  teacher    User         @relation("TeacherMemos", fields: [teacherId], references: [id], onDelete: Cascade)
  class      Class?       @relation(fields: [classId], references: [id], onDelete: SetNull)

  @@index([teacherId, archived])
}

model ReportData {
  id                String   @id @default(cuid())
  studentId         String
  monthStr          String
  comment           String?
  growth            String?
  attendanceSummary String?
  assignmentSummary String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  student           User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, monthStr])
}

model Complaint {
  id        String          @id @default(cuid())
  studentId String
  content   String
  response  String?
  aiDraft   String?
  status    ComplaintStatus @default(PENDING)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  student   User            @relation("ComplaintStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
}

model ChurnPrediction {
  id               String     @id @default(cuid())
  studentId        String
  score            Int
  level            ChurnLevel
  attendanceFactor Int
  homeworkFactor   Int
  accessFactor     Int
  questionFactor   Int
  calculatedAt     DateTime   @default(now())
  createdAt        DateTime   @default(now())
  student          User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, calculatedAt])
}

model CopilotSession {
  id        String               @id @default(cuid())
  lessonId  String
  teacherId String?
  topic     String?
  status    CopilotSessionStatus @default(ACTIVE)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  lesson    Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  teacher   User?                @relation("CopilotTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  questions CopilotQuestion[]
}

model CopilotQuestion {
  id        String         @id @default(cuid())
  sessionId String
  question  String
  beginner  String?
  example   String?
  advanced  String?
  summary   String?
  usedCards String[]       @default([])
  createdAt DateTime       @default(now())
  session   CopilotSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model RecordingSummary {
  id         String          @id @default(cuid())
  lessonId   String
  audioUrl   String?
  transcript String?
  summary    String?
  questions  String?
  nextPoints String?
  status     RecordingStatus @default(PROCESSING)
  progress   Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  lesson     Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model BotQuestion {
  id            String            @id @default(cuid())
  studentId     String
  classId       String?
  question      String
  aiAnswer      String?
  teacherAnswer String?
  helpful       Boolean?
  status        BotQuestionStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  student       User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class         Class?            @relation(fields: [classId], references: [id], onDelete: SetNull)
}

model BotFAQ {
  id        String    @id @default(cuid())
  classId   String?
  question  String
  answer    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  class     Class?    @relation(fields: [classId], references: [id], onDelete: SetNull)
}

model ReviewSummary {
  id        String    @id @default(cuid())
  studentId String
  lessonId  String?
  summary   String
  quiz      Json?
  preview   String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  student   User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson    Lesson?   @relation(fields: [lessonId], references: [id], onDelete: SetNull)
}

model AppSetting {
  id        String   @id @default(cuid())
  academyId String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  academy   Academy  @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@unique([academyId, key])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
